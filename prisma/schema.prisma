generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Pet {
  id              String                  @id @default(auto()) @map("_id") @db.ObjectId
  breed           String
  gender          String
  internalId      String?
  isDeceased      Boolean?                @default(false)
  isNeutered      Boolean
  microchipNumber String?
  name            String
  species         String
  userId          String                  @db.ObjectId
  weight          Float
  createdAt       DateTime                @default(now()) @db.Date  
  updatedAt       DateTime                @updatedAt @db.Date      
  dateOfBirth     DateTime?               @db.Date    
  user            Staff                   @relation(fields: [userId], references: [id])
  medicalHistory  MedicalHistory[]
  vaccinations    vaccinations[]
  dewormings      Deworming[]
  appointments    Appointment[]
  vacSchedules    vaccination_schedules[]
  visitHistory    VisitHistory[]

  @@index([name])
  @@index([microchipNumber])
  @@index([species, breed])
}

model MedicalHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  diagnosis      String
  notes          String?
  petId          String   @db.ObjectId
  prescriptions  String[]
  reasonForVisit String
  treatment      String
  visitDate      DateTime @db.Date
  createdAt      DateTime @default(now()) @db.Date
  updatedAt      DateTime @updatedAt @db.Date
  pet            Pet      @relation(fields: [petId], references: [id])

  @@index([petId, visitDate])
}

model Deworming {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  applicationDate DateTime  @db.Date
  petId           String    @db.ObjectId
  productId       String    @db.ObjectId
  notes           String?
  createdAt       DateTime  @default(now()) @db.Date
  updatedAt       DateTime  @updatedAt @db.Date
  pet             Pet       @relation(fields: [petId], references: [id])
  product         medicines @relation(fields: [productId], references: [id])

  @@index([petId, applicationDate])
}

model Appointment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  petId     String   @db.ObjectId
  date      DateTime @db.Date
  reason    String
  status    String   @default("scheduled") // scheduled, completed, cancelled
  notes     String?
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
  pet       Pet      @relation(fields: [petId], references: [id])

  @@index([petId, date])
  @@index([date, status])
}

model Staff {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  address       String?
  email         String?     @unique(map: "users_email_key") // Mantenemos el único y removemos el índice
  firstName     String?
  lastName      String?
  internalId    String?     @unique(map: "users_internalId_key")
  kindeId       String      @unique(map: "users_kindeId_key")
  name          String?
  nextVisitFree Boolean     @default(false)
  phone         String?
  roles         String[]
  visits        BigInt      @default(0)
  createdAt     DateTime    @default(now()) @db.Date
  updatedAt     DateTime    @updatedAt @db.Date
  pets          Pet[]
  userRoles     userRoles[]

  @@index([firstName, lastName, phone], map: "users_firstName_lastName_phone_idx")
}

model vaccinations {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  administrationDate DateTime @db.Date
  batchNumber        String?
  manufacturer       String? // Cambiado de Json? a String?
  nextDoseDate       DateTime @db.Date
  notes              String? // Cambiado de Json? a String?
  petId              String   @db.ObjectId
  stage              String
  status             String
  vaccineType        String
  veterinarianName   String?
  createdAt          DateTime @default(now()) @db.Date
  updatedAt          DateTime @updatedAt @db.Date
  pet                Pet      @relation(fields: [petId], references: [id])

  @@index([petId, vaccineType])
  @@index([nextDoseDate, status])
}

model vaccination_schedules {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  petId         String   @db.ObjectId // Cambiado de Json? a String
  scheduledDate DateTime @db.Date // Cambiado de Json? a DateTime
  status        String   @default("pending") // Cambiado de Json? a String
  vaccineType   String
  notes         String?
  createdAt     DateTime @default(now()) @db.Date
  updatedAt     DateTime @updatedAt @db.Date
  pet           Pet      @relation(fields: [petId], references: [id])

  @@index([petId, scheduledDate, status])
}

model medicines {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  activeCompound String?
  batchNumber    String? // Cambiado de Json? a String?
  brand          String? // Cambiado de Json? a String?
  category       String
  description    String?
  expirationDate DateTime?   @db.Date
  location       String? // Cambiado de Json? a String?
  measure        String?
  minStock       Int? // Cambiado de BigInt? a Int?
  name           String
  presentation   String?
  quantity       Int // Cambiado de BigInt a Int
  specialNotes   String?
  status         String
  createdAt      DateTime    @default(now()) @db.Date
  updatedAt      DateTime    @updatedAt @db.Date
  dewormings     Deworming[]

  @@index([name])
  @@index([category])
  @@index([expirationDate])
}

model stock_movements {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @db.Date
  itemId    String   @db.ObjectId
  notes     String?
  quantity  Int // Cambiado de BigInt a Int
  reason    String
  type      String
  userId    String   @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  @@index([itemId, date])
  @@index([userId, date])
}

model VisitHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  petId     String   @db.ObjectId
  date      DateTime @db.Date
  reason    String
  diagnosis String?
  treatment String?
  notes     String?
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
  pet       Pet      @relation(fields: [petId], references: [id])

  @@index([petId, date])
}

model roles {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  key       String      @unique
  name      String
  userRoles userRoles[]
}

model userRoles {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  roleId String @db.ObjectId
  userId String @db.ObjectId
  role   roles  @relation(fields: [roleId], references: [id])
  user   Staff  @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}
